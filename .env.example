# Copy to .env. Compose reads it; config.toml ${VAR} placeholders resolve from here too.

# Postgres (compose provisions the DB with these)
POSTGRES_USER=indexer
POSTGRES_PASSWORD=indexer
POSTGRES_DB=indexer
POSTGRES_PORT=5432

# Used by config.toml database.url = "${DATABASE_URL}".
# Compose overrides this to point at the postgres service; keep in sync if you change creds.
DATABASE_URL=postgres://indexer:indexer@postgres:5432/indexer

# RPC source secrets referenced by config.toml
ALCHEMY_HTTP=
ALCHEMY_WS=

# Runtime
RUST_LOG=info
CHAIN_ID=1
QUERY_PORT=8080
